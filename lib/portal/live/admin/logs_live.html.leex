<div class="content medium">
  <div class="header-box">
    <h2>
      <strong><%= @total_entries %></strong>
      actions
    </h2>

    <div class="pagination">
      <%= if @page_number == 1 do %>
        <span class="disabled">
          <i class="fa fa-angle-left"></i>
        </span>
      <% else %>
        <.link navigate={Routes.live_path(@socket, Portal.LogsLive, page: @page_number - 1)}>
          <i class="fas fa-angle-left"></i>
        </.link>
      <% end %>
      <span class="active">
        <%= @page_number %>
      </span>
      <%= if @page_number == @total_pages do %>
        <span class="disabled">
          <i class="fas fa-angle-right"></i>
        </span>
      <% else %>
        <.link navigate={Routes.live_path(@socket, Portal.LogsLive, page: @page_number + 1)}>
          <i class="fas fa-angle-right"></i>
        </.link>
      <% end %>
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th class="square"></th>
        <th>Type</th>
        <th></th>
        <th>Compte</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <%= for log <- @logs do %>
        <tr>
          <td class="square">
            <%= log.id %>
          </td>
          <td>
            <strong><%= RC.Logs.Log.action_name(log.action) %></strong>
          </td>
          <td>
            <.link navigate={Routes.live_path(@socket, Portal.AccountLive, log.account_id)}>
              <i class="fas fa-user"></i>
              #<%= log.account_id %>
            </.link>
            <%= if not is_nil(log.account.steam_id) do %>
            (steam)
            <% end %>
          </td>
          <td>
            <.link navigate={Routes.live_path(@socket, Portal.AccountLive, log.account_id)}>
              <%= log.account.name %>
            </.link>
          </td>
          <td>
            <%= Portal.Date.format(log.inserted_at, :datetime) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
