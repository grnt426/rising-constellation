# Production environment contract for Rising Constellation.
#
# Required env vars are read in config/runtime.exs at release boot. Missing
# required vars will crash the release with a clear error — intentionally,
# so misconfigured deploys fail loudly.
#
# In AWS, these are populated from Secrets Manager into a systemd
# EnvironmentFile= on the EC2 instance. For local dev under MIX_ENV=prod
# you can `cp .env.example .env` and `set -a; source .env; set +a` before
# `mix phx.server`. Standard MIX_ENV=dev does NOT read this file — see
# config/dev.exs.
#
# Emergency / local-testing override:
#   Set RC_SECRET_FILE=/path/to/secret.json before invoking
#   rc-fetch-secrets or bootstrap-host.sh, and the secret will be read
#   from that file instead of from AWS Secrets Manager. Useful when AWS
#   is unreachable or for testing the deploy pipeline against a
#   non-AWS host.

# --- Required ---------------------------------------------------------------

# Public hostname (no scheme, no trailing slash).
RC_HOST=example.com

# Phoenix secret_key_base — used to sign session cookies. Generate with:
#   mix phx.gen.secret
SECRET_KEY_BASE=

# Guardian JWT signing key. Generate with:
#   mix phx.gen.secret
GUARDIAN_SECRET_KEY=

# Postgres connection URL. Format:
#   ecto://USER:PASS@HOST:PORT/DBNAME
# For RDS, append ?ssl=true and set DATABASE_SSL=true below.
DATABASE_URL=ecto://rcprod:CHANGEME@localhost:5432/rc_prod

# Mailjet credentials (or whatever Swoosh adapter you swap in).
MAILER_API_KEY=
MAILER_SECRET=

# S3-compatible object storage for Waffle user uploads.
S3_BUCKET=rc-uploads-prod
S3_ASSET_HOST=https://rc-uploads-prod.s3.amazonaws.com/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Optional (sensible defaults in runtime.exs) ----------------------------

# Defaults: https on 443, Phoenix on 4000, RC_DOMAIN = scheme://host/
RC_SCHEME=https
RC_URL_PORT=443
RC_HTTP_PORT=4000
RC_DOMAIN=https://example.com/

# Force redirect to HTTPS + emit HSTS + flag cookies secure. Defaults to true
# (the right thing in real prod, behind a TLS-terminating ALB/proxy). Set to
# false for HTTP-only test/staging deploys where the host is reached via
# plain HTTP — otherwise the browser caches HSTS for a year and refuses to
# speak HTTP to the host, and secure cookies prevent any session from sticking.
RC_FORCE_SSL=true

# Outbound emails are addressed from this sender.
# Defaults: name="Rising Constellation", email="support@$RC_HOST"
MAILER_SENDER_NAME=Rising Constellation
MAILER_SENDER_EMAIL=support@example.com

# Shown in user-facing pages (Terms of Service, contact links).
# Default: support@$RC_HOST
RC_SUPPORT_EMAIL=support@example.com

# Account flow. Valid signup modes: disabled | manual_validation | mail_validation
# Valid login modes: disabled | enabled
RC_SIGNUP_MODE=mail_validation
RC_LOGIN_MODE=enabled

# Ecto pool size. Bump for higher concurrency.
POOL_SIZE=10

# Enable for RDS / any TLS-protected Postgres.
DATABASE_SSL=false

# Mailjet template IDs. Defaults are the original templates (likely no longer
# exist in your account — recreate them, then set the IDs here).
MAILER_VERIFICATION_TEMPLATE=1352021
MAILER_PASSWORD_RESET_TEMPLATE=1363520
MAILER_EMAIL_UPDATE_TEMPLATE=1699096
MAILER_WEB_BIND_TEMPLATE=3028081

# S3 endpoint. Override for non-AWS providers (Backblaze B2, Scaleway, R2).
AWS_REGION=us-east-1
S3_HOST=s3.amazonaws.com
S3_SCHEME=https://
S3_STORAGE_DIR=/storage

# Stripe (only required if billing is enabled in your build). Leave unset to
# skip Stripe configuration entirely.
# STRIPE_API_KEY=
# STRIPE_PUBLIC_KEY=

# Steam integration (only required if shipping via Steam).
# STEAMWORKS_WEB_API_SECRET=

# AppSignal observability. Set ACTIVE=true and provide PUSH_API_KEY to enable.
APPSIGNAL_ACTIVE=false
# APPSIGNAL_PUSH_API_KEY=

# GELF log shipping. Leave GELF_HOST unset to log to console instead.
# GELF_HOST=
GELF_PORT=12201
RC_ENV_TAG=prod

# libcluster. Leave RC_CLUSTER_DNS unset for single-node operation. Set to a
# DNS name resolving to all node IPs to enable DNSPoll-based discovery.
# RC_CLUSTER_DNS=nodes.example.com
RC_CLUSTER_BASENAME=rc

# Erlang distributed-node name. The release defaults to RELEASE_DISTRIBUTION=name
# (long names) per rel/env.sh.eex, so net_kernel needs *some* name to bind.
# Single-node: rc@127.0.0.1 is fine. Multi-node clustering: use the instance's
# private IP, e.g. rc@10.0.1.5.
RELEASE_NODE=rc@127.0.0.1

# Erlang distributed cookie. Required only if you cluster nodes; even on a
# single node, the release scripts touch it. Generate with `openssl rand -hex 32`.
RELEASE_COOKIE=changeme-cluster-cookie

# --- Vue build-time vars (consumed by build-front.sh, NOT runtime) ----------
# These bake into the JS bundle at build time. Set them in the CI/build
# environment, not on the production host.

# Vue's base URL — used by the SPA to call back to /api and /socket.
VUE_APP_BASE_URL=https://example.com

# AppSignal frontend key (optional). Leave unset to disable frontend monitoring.
# VUE_APP_APPSIGNAL_FRONT=
