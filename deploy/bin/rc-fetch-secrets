#!/bin/bash
#
# Pull the Rising Constellation env-var blob and write it to /etc/rc/env in
# the KEY=VALUE format that systemd's EnvironmentFile= directive expects.
#
# Two sources, in priority order:
#
#   1. RC_SECRET_FILE — local JSON file path. Skips AWS entirely. Useful
#      for local testing, or as an emergency override on prod when AWS is
#      unreachable.
#   2. AWS Secrets Manager — the default. RC_SECRET_ID names the secret,
#      AWS_REGION sets the region. The EC2 instance role is expected to
#      have GetSecretValue permission on the target secret. No long-lived
#      AWS credentials live on the host.
#
# The JSON payload (whichever source) MUST be an object of string→string
# entries matching the env contract in .env.example.
#
# Invoked by rc-fetch-secrets.service (oneshot, before rc.service).

set -euo pipefail

OUT="/etc/rc/env"
TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT

if [[ -n "${RC_SECRET_FILE:-}" ]]; then
  echo "rc-fetch-secrets: reading from local file $RC_SECRET_FILE"
  if [[ ! -r "$RC_SECRET_FILE" ]]; then
    echo "rc-fetch-secrets: $RC_SECRET_FILE missing or unreadable" >&2
    exit 1
  fi
  secret_json=$(cat "$RC_SECRET_FILE")
else
  SECRET_ID="${RC_SECRET_ID:-rc/prod/env}"
  REGION="${AWS_REGION:-us-east-1}"
  echo "rc-fetch-secrets: reading from Secrets Manager ($SECRET_ID in $REGION)"
  secret_json=$(aws secretsmanager get-secret-value \
    --secret-id "$SECRET_ID" \
    --region "$REGION" \
    --query SecretString \
    --output text)
fi

if [[ -z "$secret_json" ]]; then
  echo "rc-fetch-secrets: empty secret payload" >&2
  exit 1
fi

# Render each entry as KEY='value'. systemd's EnvironmentFile= treats
# single-quoted values literally — no shell-style expansion, no escape
# sequences. The @sh formatter from jq handles the single-quote escape
# safely (' becomes '\''), which is also exactly how systemd unquotes.
echo "$secret_json" | jq -er '
  if type != "object" then
    error("secret payload must be a JSON object, got \(type)")
  else
    to_entries[] |
      if (.value | type) != "string" then
        error("value for key \(.key) must be a string, got \(.value | type)")
      else
        "\(.key)=\(.value | @sh)"
      end
  end
' > "$TMP"

# Atomic install. Mode 0600, owned by rc:rc — only the release reads it.
install -o rc -g rc -m 0600 "$TMP" "$OUT"

echo "rc-fetch-secrets: wrote $(wc -l < "$OUT") env vars to $OUT"
