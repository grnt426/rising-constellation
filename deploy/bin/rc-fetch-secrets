#!/bin/bash
#
# Pull the Rising Constellation env-var blob from AWS Secrets Manager and
# write it to /etc/rc/env in the KEY=VALUE format that systemd's
# EnvironmentFile= directive expects.
#
# Usage: invoked by rc-fetch-secrets.service (oneshot, before rc.service).
#
# Env:
#   RC_SECRET_ID  — name or ARN of the Secrets Manager secret (default:
#                   rc/prod/env). The secret value MUST be a JSON object
#                   whose keys/values are the env-var contract documented
#                   in .env.example.
#   AWS_REGION    — region (default: us-east-1)
#
# The EC2 instance role is expected to have permission to call
# secretsmanager:GetSecretValue on the target secret. No long-lived AWS
# credentials live on the host.

set -euo pipefail

SECRET_ID="${RC_SECRET_ID:-rc/prod/env}"
REGION="${AWS_REGION:-us-east-1}"
OUT="/etc/rc/env"
TMP="$(mktemp)"
trap 'rm -f "$TMP"' EXIT

# Fetch the secret. --query SecretString gets us the raw JSON payload.
secret_json=$(aws secretsmanager get-secret-value \
  --secret-id "$SECRET_ID" \
  --region "$REGION" \
  --query SecretString \
  --output text)

if [[ -z "$secret_json" ]]; then
  echo "rc-fetch-secrets: empty secret payload for $SECRET_ID" >&2
  exit 1
fi

# Render each entry as KEY='value'. systemd's EnvironmentFile= treats
# single-quoted values literally — no shell-style expansion, no escape
# sequences. The @sh formatter from jq handles the single-quote escape
# safely (' becomes '\''), which is also exactly how systemd unquotes.
echo "$secret_json" | jq -er '
  if type != "object" then
    error("RC_SECRET_ID payload must be a JSON object, got \(type)")
  else
    to_entries[] |
      if (.value | type) != "string" then
        error("value for key \(.key) must be a string, got \(.value | type)")
      else
        "\(.key)=\(.value | @sh)"
      end
  end
' > "$TMP"

# Atomic install. Mode 0600, owned by rc:rc — only the release reads it.
install -o rc -g rc -m 0600 "$TMP" "$OUT"

echo "rc-fetch-secrets: wrote $(wc -l < "$OUT") env vars to $OUT"
