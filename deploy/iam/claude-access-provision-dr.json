{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "BackupBucketProvision",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:ListBucket",
        "s3:GetBucketLocation",
        "s3:PutBucketPublicAccessBlock",
        "s3:PutEncryptionConfiguration",
        "s3:PutLifecycleConfiguration"
      ],
      "Resource": "arn:aws:s3:::rc-prod-backups-553872001542"
    },
    {
      "Sid": "BackupObjectsRead",
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::rc-prod-backups-553872001542/*"
    },
    {
      "Sid": "InstanceRoleProvision",
      "Effect": "Allow",
      "Action": [
        "iam:GetRole",
        "iam:CreateRole",
        "iam:PutRolePolicy",
        "iam:GetInstanceProfile",
        "iam:CreateInstanceProfile",
        "iam:AddRoleToInstanceProfile"
      ],
      "Resource": [
        "arn:aws:iam::553872001542:role/rc-prod-instance-role",
        "arn:aws:iam::553872001542:instance-profile/rc-prod-instance-profile"
      ]
    },
    {
      "Sid": "PassRoleToEc2",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::553872001542:role/rc-prod-instance-role",
      "Condition": {
        "StringEquals": { "iam:PassedToService": "ec2.amazonaws.com" }
      }
    },
    {
      "Sid": "DescribeProfileAssociations",
      "Effect": "Allow",
      "Action": ["ec2:DescribeIamInstanceProfileAssociations"],
      "Resource": "*"
    },
    {
      "Sid": "AttachProfileToProdInstance",
      "Effect": "Allow",
      "Action": ["ec2:AssociateIamInstanceProfile"],
      "Resource": "arn:aws:ec2:us-east-1:553872001542:instance/i-017d81bd1155ebfb3"
    },
    {
      "Sid": "EnvSecretProvision",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:DescribeSecret",
        "secretsmanager:CreateSecret",
        "secretsmanager:PutSecretValue"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-1:553872001542:secret:rc/prod/env*"
    }
  ]
}
