#!/usr/bin/env bash
# rc-worktree-setup — allocate isolated host ports for this worktree so multiple
# worktrees can run their Docker dev stacks in parallel without colliding.
#
# Run from anywhere inside a worktree. Writes .env and .dev-ports.json at the
# worktree root (both gitignored). Re-running is idempotent: the registry at
# $XDG_CONFIG_HOME/rc/worktree-ports.tsv (or %LOCALAPPDATA%\rc on Windows) maps
# absolute worktree path → slot, so the same worktree gets the same ports
# across recreations of its Docker stack.

set -euo pipefail

MODE=allocate
case "${1:-}" in
    --gc)         MODE=gc ;;
    -h|--help)
        cat <<EOF
Usage: rc-worktree-setup [--gc]

  (no args)   Allocate or reuse a port slot for the current worktree.
              Writes .env and .dev-ports.json at the worktree root.
  --gc        Prune registry entries whose worktree paths no longer exist
              on disk. Prints what was removed.
EOF
        exit 0
        ;;
    "" ) ;;
    *)
        echo "error: unknown argument: $1" >&2
        exit 2
        ;;
esac

if [ -n "${LOCALAPPDATA:-}" ]; then
    REG_DIR="$LOCALAPPDATA/rc"
elif [ -n "${XDG_CONFIG_HOME:-}" ]; then
    REG_DIR="$XDG_CONFIG_HOME/rc"
else
    REG_DIR="$HOME/.config/rc"
fi
REG_FILE="$REG_DIR/worktree-ports.tsv"
mkdir -p "$REG_DIR"
touch "$REG_FILE"

if [ "$MODE" = "gc" ]; then
    # No git rev-parse needed — we operate on the registry only.
    tmp=$(mktemp "$REG_FILE.XXXXXX")
    removed=0
    kept=0
    while IFS=$'\t' read -r path slot ts; do
        [ -z "${path:-}" ] && continue
        # On Windows, registry paths use backslashes; bash test handles them.
        if [ -d "$path" ]; then
            printf '%s\t%s\t%s\n' "$path" "$slot" "$ts" >> "$tmp"
            kept=$((kept + 1))
        else
            echo "  pruned slot $slot: $path"
            removed=$((removed + 1))
        fi
    done < "$REG_FILE"
    mv "$tmp" "$REG_FILE"
    echo "Garbage-collected $removed stale entries, kept $kept."
    exit 0
fi

if ! WORKTREE=$(git rev-parse --show-toplevel 2>/dev/null); then
    echo "error: not inside a git repository" >&2
    exit 1
fi

LOCK="$REG_FILE.lock"
if command -v flock >/dev/null 2>&1; then
    exec 9>"$LOCK"
    flock 9
else
    tries=0
    while ! mkdir "$LOCK.d" 2>/dev/null; do
        tries=$((tries + 1))
        if [ "$tries" -gt 50 ]; then
            echo "error: could not acquire registry lock at $LOCK.d" >&2
            exit 1
        fi
        sleep 0.1
    done
    trap 'rmdir "$LOCK.d" 2>/dev/null || true' EXIT
fi

# SHA-1 of the absolute path → preferred slot in [0..99]. 7 hex chars keeps
# the intermediate value safely within 32-bit signed range on any bash.
if command -v sha1sum >/dev/null 2>&1; then
    HASH_HEX=$(printf '%s' "$WORKTREE" | sha1sum | cut -c1-7)
elif command -v shasum >/dev/null 2>&1; then
    HASH_HEX=$(printf '%s' "$WORKTREE" | shasum -a 1 | cut -c1-7)
else
    echo "error: need sha1sum or shasum on PATH" >&2
    exit 1
fi
SLOT_PREF=$(( 0x$HASH_HEX % 100 ))

EXISTING_SLOT=$(awk -F'\t' -v p="$WORKTREE" '$1 == p { print $2; exit }' "$REG_FILE")

REUSED=0
if [ -n "$EXISTING_SLOT" ]; then
    SLOT=$EXISTING_SLOT
    REUSED=1
else
    declare -A CLAIMED=()
    while IFS=$'\t' read -r path slot _; do
        [ -z "${path:-}" ] && continue
        [ "$path" = "$WORKTREE" ] && continue
        CLAIMED[$slot]=1
    done < "$REG_FILE"

    port_in_use() {
        local port=$1
        if command -v ss >/dev/null 2>&1; then
            ss -lnt 2>/dev/null | awk -v p=":$port" '$4 ~ p"$" { found=1 } END { exit !found }'
        elif command -v netstat >/dev/null 2>&1; then
            netstat -lnt 2>/dev/null | awk -v p=":$port" '$4 ~ p"$" { found=1 } END { exit !found }'
        else
            (exec 3<>"/dev/tcp/127.0.0.1/$port") 2>/dev/null && { exec 3<&- 3>&-; return 0; }
            return 1
        fi
    }

    SLOT=""
    for offset in $(seq 0 99); do
        cand=$(( (SLOT_PREF + offset) % 100 ))
        if [ -n "${CLAIMED[$cand]:-}" ]; then continue; fi
        http=$(( 4000 + cand * 10 ))
        front=$(( 8080 + cand * 10 ))
        if port_in_use "$http" || port_in_use "$front"; then continue; fi
        SLOT=$cand
        break
    done

    if [ -z "$SLOT" ]; then
        echo "error: no free slot among 100 candidates (4000-4990 range)" >&2
        exit 1
    fi

    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    printf '%s\t%s\t%s\n' "$WORKTREE" "$SLOT" "$ts" >> "$REG_FILE"
fi

HTTP_PORT=$(( 4000 + SLOT * 10 ))
FRONT_PORT=$(( 8080 + SLOT * 10 ))

base=$(basename "$WORKTREE")
slug=$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9-]+/-/g; s/^-+//; s/-+$//')
[ -z "$slug" ] && slug="worktree"
PROJECT_NAME="rc-$slug"

cat > "$WORKTREE/.env" <<EOF
# Auto-generated by bin/rc-worktree-setup. Re-run the script to refresh.
# Gitignored — per-machine port assignments for parallel worktrees.
COMPOSE_PROJECT_NAME=$PROJECT_NAME
RC_HTTP_PORT=$HTTP_PORT
RC_FRONT_PORT=$FRONT_PORT
EOF

worktree_json=${WORKTREE//\\/\\\\}
cat > "$WORKTREE/.dev-ports.json" <<EOF
{
  "_readme": "Auto-generated. AI agents: when this stack is running, hit the ports below — NOT the defaults 4000/8080.",
  "worktree": "$worktree_json",
  "project": "$PROJECT_NAME",
  "slot": $SLOT,
  "ports": {
    "phoenix": $HTTP_PORT,
    "vue_spa": $FRONT_PORT
  }
}
EOF

echo
if [ "$REUSED" = "1" ]; then
    echo "Reused existing slot $SLOT for this worktree."
else
    echo "Allocated slot $SLOT for this worktree (preferred: $SLOT_PREF)."
fi
echo "  Phoenix:    http://localhost:$HTTP_PORT"
echo "  Vue SPA:    http://localhost:$FRONT_PORT"
echo "  Project:    $PROJECT_NAME"
echo
echo "Bring the stack up with: docker compose up"
